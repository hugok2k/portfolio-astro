---
export interface Props {
  title: string
  description: string
  github: string
  deploy: string
  image: string
  tools: string[]
  number: number
}

const { title, description, github, deploy, image, tools, number } = Astro.props

import { toolsMap } from "../utils/ToolsIcons"
import Github from "./svg/github.astro"
import LinkEx from "./svg/link.astro"

const slug = title
  .toLowerCase()
  .replace(/[^a-z0-9]+/g, "-")
  .replace(/(^-|-$)/g, "")

const ctaClass =
  "inline-flex items-center gap-2 font-mono text-xs md:text-sm px-3 py-1.5 border border-(--color-text-base)/25 text-(--color-text-base) fill-(--color-text-base) hover:border-primary hover:text-primary hover:fill-primary transition-colors duration-200"
---

<article class="relative flex flex-col w-full h-full border border-(--color-text-base)/15 hover:border-primary/50 bg-(--color-bg) transition-colors duration-300">
  <div class="flex items-center gap-2 px-4 py-2.5 border-b border-(--color-text-base)/15" aria-hidden="true">
    <span class="flex gap-1.5">
      <span class="w-2 h-2 rounded-full bg-(--color-text-base)/15"></span>
      <span class="w-2 h-2 rounded-full bg-(--color-text-base)/15"></span>
      <span class="w-2 h-2 rounded-full bg-primary/50"></span>
    </span>
    <span class="flex-1 text-center font-mono text-[11px] text-(--color-text-base)/35 truncate px-2">~/proyectos/{slug}</span>
    <span class="font-mono text-[11px] text-primary shrink-0">P_{number.toString().padStart(2, "0")}</span>
  </div>

  <a
    class="group relative w-full h-56 overflow-hidden flex justify-center items-center border-b border-(--color-text-base)/15"
    href={deploy}
    target="_blank"
    rel="noreferrer noopener"
    aria-label={`Ver proyecto ${title}`}
  >
    <img
      class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
      src={image}
      alt={title}
      loading="lazy"
    />
    <span class="absolute inset-0 flex items-center justify-center gap-2 bg-(--color-bg)/95 fill-(--color-text-base) opacity-0 group-hover:opacity-100 transition-opacity duration-300 font-mono text-xs md:text-sm uppercase tracking-widest">
      <LinkEx height="16" width="16" />
      ver proyecto
    </span>
  </a>

  <div class="flex flex-col flex-1 px-5 py-5">
    <a
      class="font-bold text-lg md:text-xl text-(--color-text-base) hover:text-primary transition-colors duration-200 mb-2 text-balance"
      href={deploy}
      target="_blank"
      rel="noreferrer noopener"
    >
      {title}
    </a>
    <p class="text-sm text-(--color-text-base)/70 leading-relaxed mb-5 line-clamp-3">
      {description}
    </p>

    <ul class="flex flex-wrap gap-2 mb-5" aria-label="Tecnologías utilizadas">
      {
        tools.map((tool) => {
          const IconComponent = toolsMap[tool as keyof typeof toolsMap]
          return (
            <li class="inline-flex items-center gap-1.5 font-mono text-[11px] px-2.5 py-1 border border-(--color-text-base)/20 text-(--color-text-base)/70">
              {IconComponent && (
                <span class="w-3 h-3 flex items-center justify-center shrink-0">
                  <IconComponent />
                </span>
              )}
              {tool}
            </li>
          )
        })
      }
    </ul>

    <div class="flex flex-wrap gap-3 mt-auto pt-5 border-t border-(--color-text-base)/15">
      <a class={ctaClass} href={deploy} target="_blank" rel="noreferrer noopener" aria-label={`Link hacia la demo de ${title}`}>
        <LinkEx height="14" width="14" />
        ver proyecto
      </a>
      {
        github !== "" && (
          <a class={ctaClass} href={github} target="_blank" rel="noreferrer noopener" aria-label={`Link a github de ${title}`}>
            <Github height="14" width="14" />
            repositorio
          </a>
        )
      }
    </div>
  </div>
</article>
