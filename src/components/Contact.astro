---
import Button from "./ui/Button.astro"
---

  <section class="flex flex-col justify-center items-center w-full px-4 mt-10 md:mt-52 pb-20 md:pb-32">
  <h2
    class="text-3xl md:text-6xl font-bold pt-4 max-w-3xl text-balance text-center text-(--color-text-base) scroll-mt-20 md:scroll-mt-40"
    id="contact"
  >
    ¿Listo para empezar tu <span class="text-primary">próximo proyecto</span>?
  </h2>
  <h3 class="font-mono text-sm md:text-lg mt-4 mb-2 text-primary text-balance text-center">
    <span class="opacity-50">$</span> contacto --send
  </h3>
  <p class="font-mono text-xs text-(--color-text-base)/70 mb-10">// hablemos de cómo podemos colaborar</p>

  <div class="w-full max-w-3xl" id="formBlock">
    <div class="border border-(--color-text-base)/15 bg-(--color-bg)/70">
      <div class="flex items-center gap-2 px-4 py-2.5 border-b border-(--color-text-base)/15" aria-hidden="true">
        <span class="flex gap-1.5">
          <span class="w-2 h-2 rounded-full bg-(--color-text-base)/15"></span>
          <span class="w-2 h-2 rounded-full bg-(--color-text-base)/15"></span>
          <span class="w-2 h-2 rounded-full bg-primary/50"></span>
        </span>
        <span class="flex-1 text-center font-mono text-[11px] text-(--color-text-base)/35">~/hugo/contacto.sh</span>
      </div>

      <form id="someForm" class="flex flex-col gap-2 px-6 py-8 md:px-10 md:py-10">
        <label for="name" class="font-mono text-xs uppercase tracking-wider text-(--color-text-base)/70 mb-1">nombre</label>
        <input
          class="bg-transparent w-full border border-(--color-text-base)/20 px-4 py-2.5 mb-4 outline-none focus:border-primary transition-colors duration-300 text-(--color-text-base)"
          type="text"
          name="name"
          id="name"
          placeholder="Ej: John Doe"
          required
        />
        <label for="email" class="font-mono text-xs uppercase tracking-wider text-(--color-text-base)/70 mb-1">correo</label>
        <input
          class="bg-transparent w-full border border-(--color-text-base)/20 px-4 py-2.5 mb-4 outline-none focus:border-primary transition-colors duration-300 text-(--color-text-base)"
          type="email"
          name="email"
          id="email"
          placeholder="Ej: john@doe.com"
          required
        />
        <label for="comments" class="font-mono text-xs uppercase tracking-wider text-(--color-text-base)/70 mb-1">mensaje</label>
        <textarea
          name="comments"
          id="comments"
          rows="8"
          placeholder="Escribe tu mensaje."
          required
          class="bg-transparent w-full border border-(--color-text-base)/20 px-4 py-2.5 outline-none focus:border-primary transition-colors duration-300 text-(--color-text-base)"
        ></textarea>
        <input type="hidden" name="_next" value="https://hugoavila.dev/gracias" />
        <Button title="Enviar" id="submitButton" type="submit" classname="mt-7 g-recaptcha max-w-36" />
      </form>
    </div>
  </div>

  <div id="thankyouBlock" class="flex-col justify-center items-center min-h-96 hidden w-full max-w-3xl border border-(--color-text-base)/15 bg-(--color-bg)/70 px-6 py-10 text-center">
    <p class="font-mono text-xs text-primary mb-3"><span class="opacity-50">$</span> status --sent</p>
    <h4 class="text-2xl md:text-3xl font-bold text-(--color-text-base) mb-2">Gracias por tu mensaje</h4>
    <p class="text-(--color-text-base)/70">Me pondré en contacto contigo lo antes posible</p>
    <div class="text-primary animate-pulse mt-4">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
        stroke-width="1.5"
        stroke="currentColor"
        class="size-8"
      >
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"></path>
      </svg>
    </div>
  </div>
</section>

<script>
  const someForm = document.getElementById('someForm')
  const formBlock = document.getElementById('formBlock')
  const thankyouBlock = document.getElementById('thankyouBlock')
  if (someForm === null || formBlock === null || thankyouBlock === null) {
    throw new Error('Form not found')
  }
  someForm.addEventListener('submit', function (e) {
    e.preventDefault()
    const formData = new FormData(this as HTMLFormElement)
    const requestOptions = {
      method: 'POST',
      body: formData,
      headers: {
        Accept: 'application/json'
      }
    }

    fetch('https://formspree.io/f/xblrdelg', requestOptions)
      .then((response) => {
        if (response.ok) {
          return response.json()
        } else {
          throw new Error('Something went wrong')
        }
      })
      .then(() => {
        formBlock.style.display = 'none'
        thankyouBlock.style.display = 'flex'
      })
      .catch((error) => {
        console.error('Error:', error)
      })
  })
</script>
