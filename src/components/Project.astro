---
import { data } from "../utils/data"
import Card from "./Card.astro"
import Button from "./ui/Button.astro"
---

<section class="relative flex flex-col justify-center items-center w-full px-4 mt-20 md:mt-0 pb-20 md:pb-32 overflow-hidden">
  <div
    class="pointer-events-none absolute inset-0 -z-10 opacity-[0.06]"
    style="background-image: repeating-linear-gradient(0deg, var(--color-text-base) 0px, var(--color-text-base) 1px, transparent 1px, transparent 3px); mask-image: linear-gradient(to bottom, transparent, black 15%, black 85%, transparent); -webkit-mask-image: linear-gradient(to bottom, transparent, black 15%, black 85%, transparent);"
    aria-hidden="true"
  >
  </div>

  <h2
    class="text-3xl md:text-6xl font-bold pt-4 max-w-5xl text-balance text-center text-(--color-text-base) scroll-mt-20 md:scroll-mt-40"
    id="project"
  >
    Transformando ideas en soluciones digitales robustas y seguras.
  </h2>
  <h3 class="font-mono text-sm md:text-lg mb-2 text-primary text-balance text-center">
    <span class="opacity-50">$</span> proyectos --list --total={data.length}
  </h3>
  {
    data.length > 6 && (
      <p class="font-mono text-xs text-(--color-text-base)/50 mb-6">// mostrando 6 de {data.length} proyectos</p>
    )
  }

  <div
    id="projects-list"
    class={`grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8 w-full max-w-6xl ${data.length > 6 ? "mt-8" : "mt-16"}`}
  >
    {
      data.map((e, i) => (
        <div class={`h-full ${i > 5 ? "hidden project-extra" : ""}`}>
          <Card github={e.github} title={e.title} description={e.description} image={e.image} tools={e.tools} deploy={e.deploy} number={i + 1} />
        </div>
      ))
    }
  </div>
  {data.length > 6 && <Button id="toggle-projects" title="$ ver más proyectos" classname="mt-10 font-mono text-sm" />}
</section>

<script is:inline>
const btn = document.getElementById('toggle-projects');
const extras = document.querySelectorAll('.project-extra');
let expanded = false;
if (btn) {
  btn.addEventListener('click', () => {
    expanded = !expanded;
    extras.forEach(div => div.classList.toggle('hidden', !expanded));
    btn.textContent = expanded ? '$ ver menos' : '$ ver más proyectos';
  });
}
</script>
